generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model brands {
  id       Int        @id @default(autoincrement())
  name     String     @unique(map: "sqlite_autoindex_brands_1")
  vehicles vehicles[]
}

model categories {
  id                   Int                 @id @default(autoincrement())
  vehicle_id           Int
  name                 String
  slug                 String?
  diagram_image_path   String?
  original_diagram_url String?
  vehicles             vehicles            @relation(fields: [vehicle_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  category_products    category_products[]

  @@unique([vehicle_id, slug], map: "sqlite_autoindex_categories_1")
  @@index([vehicle_id], map: "idx_category_vehicle")
}

model category_products {
  id                 Int        @id @default(autoincrement())
  category_id        Int
  product_sku        String
  diagram_ref_number String?
  products           products   @relation(fields: [product_sku], references: [sku], onDelete: Cascade, onUpdate: NoAction)
  categories         categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_sku], map: "idx_cat_prod_sku")
  @@index([category_id], map: "idx_cat_prod_cat")
}

model products {
  sku               String              @id
  name              String
  current_price     Float?
  category_products category_products[]
}

model vehicles {
  id         Int          @id @default(autoincrement())
  brand_id   Int
  year       Int
  model_name String
  slug       String?
  categories categories[]
  brands     brands       @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([brand_id, year, model_name], map: "sqlite_autoindex_vehicles_1")
  @@index([year], map: "idx_vehicle_year")
  @@index([brand_id], map: "idx_vehicle_brand")
}

// Modelos de Comercio Frontend Originals
model AppConfiguration {
  id                  String   @id @default(uuid())
  key                 String   @unique
  marginMultiplier    Float    @default(1.0)
  baseShippingCost    Float    @default(0.0)
  exchangeRate        Float    @default(515.0)
  sinpePhone          String?
  sinpeName           String?
  transferAccount     String?
  transferName        String?
  lastUpdated         DateTime @updatedAt
}

model Order {
  id              String   @id @default(uuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  totalAmount     Float
  paymentMethod   String   
  status          String   @default("PENDING")
  itemsList       String   
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
