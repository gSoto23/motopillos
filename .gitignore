# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# Prisma SQLite Database (Never commit real DBs)
prisma/*.db
prisma/*.db-journal

# Python / Scraper Env
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.env.local
.env.development.local
.env.test.local
.env.production.local
scraper/venv/

# Playwright
*.zip
*.webm
test-results/

# IDE Configuration
.vscode/
.idea/
.cursorrules

# Scraping Output
/datos_extraidos/
abs-control-unit-cbr600ra.json
scraper_*.log
# Cloud Images Cache
/lightsail_images/

# SQLite Mass Data
/*.db
